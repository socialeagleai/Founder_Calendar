# --- Database (matches docker-compose.yml) ---
DATABASE_URL=postgresql+psycopg2://founder:founder_pass@localhost:5433/founder_calendar

# --- Auth ---
# Change this to a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Google Sign-In ---
# Set to your Google OAuth Web Client ID to verify real Google credentials.
# Leave blank to use the built-in demo Google login (creates founder@google.demo),
# which mirrors the current frontend behaviour and works with zero OAuth setup.
GOOGLE_CLIENT_ID=

# --- CORS ---
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://127.0.0.1:3000

# --- Password reset ---
# Base URL of the frontend, used to build the reset link emailed to users.
APP_BASE_URL=http://localhost:8080
RESET_TOKEN_EXPIRE_MINUTES=60

# --- SMTP (outbound email) ---
# Leave SMTP_HOST blank to log reset links to the server instead of emailing.
# Example (Gmail): SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=you@gmail.com,
# SMTP_PASSWORD=<app password>, SMTP_FROM="Founder Calendar <you@gmail.com>".
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true

# --- Notifications ---
# The in-process thread that sends daily agenda digests. Leave on in normal use.
DIGEST_ENABLED=true

# --- Web Push (VAPID) ---
# Leave blank to keep push switched off - the bell and email are unaffected, and
# the Settings toggle hides itself rather than offering a switch that does
# nothing. Generate a pair with:
#   .\.venv\Scripts\python.exe -m app.gen_vapid
# The PRIVATE key is a secret: it belongs in .env (and on the VPS in
# /root/Founder_Calendar/.env), never in git.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@socialeagle.ai
